# Apple Code Signing & Notarization
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# Your 10-character Apple Team ID (find it at https://developer.apple.com/account)
APPLE_TEAM_ID=

# Your Apple ID email address
APPLE_ID=

# App-specific password (generate at https://appleid.apple.com)
APPLE_APP_SPECIFIC_PASSWORD=

# Optional: Specific certificate name to use for signing
# If not set, electron-builder will auto-select "Developer ID Application"
# CSC_NAME="Developer ID Application: Your Name (TEAM_ID)"
